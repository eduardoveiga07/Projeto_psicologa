# =============================================================================
# ARQUIVO DE EXEMPLO — NÃO COMMITE O SECRETS.TOML REAL NO GITHUB!
# Copie este arquivo para .streamlit/secrets.toml e preencha os valores reais.
# =============================================================================

# URL de conexão com o banco de dados PostgreSQL (Neon, Supabase, etc.)
DATABASE_URL = "postgresql+psycopg2://usuario:senha@host/banco?sslmode=require"

# Senha do administrador inicial (criada automaticamente no primeiro acesso)
BOOTSTRAP_ADMIN_PASSWORD = "troque-essa-senha-forte"

# Chave de criptografia para backups (gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
BACKUP_ENCRYPTION_KEY = "sua-chave-fernet-aqui"

# Ambiente: "desenvolvimento" ou "producao"
AMBIENTE = "producao"
